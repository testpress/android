<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/login_secondary_color"
    android:orientation="vertical" >

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="10dp"
            android:paddingLeft="15dp"
            android:paddingRight="15dp"
            android:paddingTop="5dp" >

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:id="@+id/form"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:id="@+id/imageView"
                    android:layout_gravity="center_horizontal"
                    android:src="@drawable/login_screen_image"
                    android:layout_marginTop="60dp"
                    android:layout_marginBottom="20dp"/>

                <!-- Email -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/username_textInput_layout"
                    style="@style/TextLabelTab"
                    android:theme="@style/TextLabel" >
                    <androidx.appcompat.widget.AppCompatEditText
                        android:id="@+id/et_useremail"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:maxLines="1"
                        android:singleLine="true"
                        style="@style/Input"
                        android:textColor="@color/login_input_text_color"
                        android:textColorHint="@color/login_input_hint_color"
                        android:hint="@string/label_email" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:id="@+id/email_error"
                    android:layout_height="wrap_content"
                    style="@style/TabInputError"/>

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/b_reset_password"
                    style="@style/Button.Tab"
                    android:layout_marginTop="20dp"
                    android:backgroundTint="@color/login_primary_button_color"
                    android:textColor="@color/login_primary_button_text_color"
                    android:text="@string/reset_password"
                    />
            </LinearLayout>

            <include layout="@layout/success_message_layout" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
